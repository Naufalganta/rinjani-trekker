generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model bookings {
  id             Int       @id @default(autoincrement())
  bookingId      String?   @db.VarChar(50)
  fullname       String?   @db.VarChar(100)
  nationality    String?   @db.VarChar(100)
  phone          String?   @db.VarChar(30)
  email          String?   @db.VarChar(100)
  service        String?   @db.VarChar(50)
  adults         Int?
  kids           Int?
  pickupDate     DateTime? @db.Date
  pickupLocation String?   @db.VarChar(150)
  trekFrom       DateTime? @db.Date
  trekTo         DateTime? @db.Date
  notes          String?   @db.Text
  paymentMethod  String?   @db.VarChar(20)
  status         String?   @default("pending") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
}
